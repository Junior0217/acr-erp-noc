# pnpm 11 · config raíz del monorepo
# Mejora supply-chain post-TanStack hack (Nov 2025).

# Auto-instala peer-deps declaradas (evita errores tipo "missing peer").
auto-install-peers=true

# Falla la instalación si HAY conflicto de peer-deps en vez de tomar la
# version más alta a ciegas. Anti-bug y anti-resolución silenciosa.
strict-peer-dependencies=true

# Cache compartido de side-effects (scripts permitidos). Acelera re-installs.
side-effects-cache=true

# Mantener node_modules aislado (default pnpm). NO promover deps a la raíz.
# Asegura que un import accidental falle si no está en package.json.
shamefully-hoist=false

# Verificación de integridad del store (hash check al instalar).
verify-store-integrity=true

# ─── Seguridad crítica anti supply-chain ─────────────────────────────────────
# Rechaza paquetes publicados hace menos de 24h (1440 min). El 95% de los
# ataques se detectan en horas y se yankean. Este buffer te salva sin que
# tengas que monitorear advisories minute-by-minute.
minimum-release-age=1440

# Si querés permitir actualizar a un paquete recién publicado SIN esperar
# 24h (caso urgente, CVE crítico), correr una sola vez:
#   pnpm install <pkg>@<ver> --allow-build --minimum-release-age=0
# pero documentar el override en el commit.

# Engine-strict: respeta `engines.node` declarado en cada package.json.
engine-strict=true

# Si una dep tiene postinstall, requiere que esté en pnpm.onlyBuiltDependencies
# del package.json raíz. Sin allowlist → scripts NO se ejecutan.
# (pnpm 11 default ya es "ignore-scripts on" para deps no listadas — esta
# línea es declarativa para que sea evidente al revisor del repo).
