{
  "name": "erp-acr",
  "version": "1.0.0",
  "private": true,
  "description": "Monorepo ERP NOC · backend Express+Prisma + frontend React+Vite. Migrado de npm a pnpm 11 para hardening supply-chain (post-TanStack hack 2025-11).",
  "engines": {
    "node": ">=20",
    "pnpm": ">=11"
  },
  "packageManager": "pnpm@11.1.3",
  "scripts": {
    "dev":         "concurrently -n \"backend,frontend\" -c \"blue,cyan\" \"pnpm --filter erp-acr-backend dev\" \"pnpm --filter frontend dev\"",
    "dev:back":    "pnpm --filter erp-acr-backend dev",
    "dev:front":   "pnpm --filter frontend dev",
    "start":       "pnpm --filter erp-acr-backend start",
    "build":       "pnpm --filter frontend build",
    "build:back":  "pnpm --filter erp-acr-backend build",
    "build:all":   "pnpm -r build",
    "icons":       "node generate-icons.js",
    "lint":        "pnpm --filter frontend lint",
    "test":        "pnpm -r test"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "sharp": "^0.34.5"
  }
}

