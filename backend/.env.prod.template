# ── Anti-tamper QR (HMAC simétrico — actual) ─────────────────────────────────
# Secret server-only para HMAC-SHA256 del verifyHash. Validación requiere
# llamar al server. Si lo cambias, las firmas viejas dejan de verificar.
VERIFY_SECRET=<< COMPLETAR: 32+ chars random — node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))" >>

# ── Anti-tamper QR (Ed25519 asimétrico — mejora #7) ──────────────────────────
# Par de claves Ed25519 raw base64. Generar UNA VEZ con:
#   node -e "console.log(require('./shared/services/ed25519-sign.service').generateNewKeyPair())"
# La PRIVATE es secret — solo en .env del server. La PUBLIC se expone vía
# GET /api/publico/verify/public-key para validación offline de QRs.
SIGN_ED25519_PRIVATE=<< COMPLETAR: 32 bytes base64 (44 chars con padding) >>
SIGN_ED25519_PUBLIC=<< COMPLETAR: 32 bytes base64 (44 chars con padding) >>

# ── Audit hash-chain (AuditCaja + AuditLog + CotizacionEvento) ───────────────
# Secret HMAC para la cadena append-only anti-tamper. Mínimo 32 chars.
# Si lo rotas, cualquier verifyChain previa fallará — solo rotar en
# eventos catastróficos (compromiso de secret). El service usa este, sino
# fallback a VAULT_KEY.
AUDIT_SECRET=<< COMPLETAR: 32+ chars random distinto de VERIFY_SECRET >>

# ── Vault PAM (AES-256-GCM cifrado credenciales) ─────────────────────────────
# Llave de 32 bytes hex (64 chars). Usada por modules/crm/credenciales para
# cifrar passwords en reposo. NO reutilizar VERIFY_SECRET ni JWT_SECRET.
VAULT_KEY=<< COMPLETAR: 64 chars hex — node -e "console.log(require('crypto').randomBytes(32).toString('hex'))" >>

# ── Redis (opcional — mejora #18 cross-process idempotency) ──────────────────
