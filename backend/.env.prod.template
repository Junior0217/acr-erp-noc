# ─────────────────────────────────────────────────────────────────────────────
# ACR Networks & Solutions — ERP NOC
# Variables de Entorno para PRODUCCIÓN (TEMPLATE)
#
# ⚠️  ESTE ARCHIVO ES SOLO TEMPLATE. NO contiene valores reales. Todos los
#     campos están como << COMPLETAR >> para que el operador los rellene en
#     local y los configure en Render Dashboard → Environment.
#
# ROTACIÓN 2026-05-19: las credenciales previas (JWT/COOKIE/DATABASE_URL
# con password Supabase) que vivían en este template fueron comprometidas
# por commit en git. Los valores actuales en Render fueron rotados; este
# template ya no expone nada.
#
# INSTRUCCIONES:
#   1. Copia este archivo como .env en tu servidor (Render → Environment tab)
#   2. Rellena los campos << COMPLETAR >>
#   3. NUNCA subas el .env real al repositorio (ya está en .gitignore)
#   4. Para generar secretos criptográficos:
#        node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
#        node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ─────────────────────────────────────────────────────────────────────────────

# ── Base de datos ─────────────────────────────────────────────────────────────
# Obtener de: Supabase → Settings → Database → Connection String (Transaction Pooler)
# IMPORTANTE: añadir ?pgbouncer=true&connection_limit=5&pool_timeout=10 al final
DATABASE_URL=<< COMPLETAR: postgresql://postgres.<proyecto>:<password>@aws-1-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=5&pool_timeout=10 >>

# DIRECT_URL (REQUERIDA para `prisma migrate deploy`). El pooler con
# pgbouncer=true NO soporta prepared statements -> migrate falla. Direct URL
# bypassa pgbouncer. Usar connection_limit=1 para evitar agotar slots prod.
DIRECT_URL=<< COMPLETAR: postgresql://postgres:<password>@db.<proyecto>.supabase.co:5432/postgres?sslmode=require&connection_limit=1 >>

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── CORS (Frontend URL de Vercel) ─────────────────────────────────────────────
# Obtener de: Vercel → tu proyecto → Settings → Domains
CORS_ORIGIN=<< COMPLETAR: https://tu-frontend.vercel.app >>

# ── Secretos JWT ──────────────────────────────────────────────────────────────
# Generar con: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=<< COMPLETAR: 48 bytes base64url (64 chars) >>
JWT_REFRESH_SECRET=<< COMPLETAR: 48 bytes base64url, distinto del anterior >>
JWT_EXPIRES=8h

# ── Cookie signing ────────────────────────────────────────────────────────────
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
COOKIE_SECRET=<< COMPLETAR: 32 bytes base64url (43 chars) >>

# ── MikroTik (mantener DRY_RUN=true hasta validar en producción) ──────────────
MIKROTIK_DRY_RUN=true
MIKROTIK_HOST=<< COMPLETAR: IP del router, ej. 192.168.88.1 >>
MIKROTIK_PORT=8728
MIKROTIK_USER=<< COMPLETAR: usuario API RouterOS >>
MIKROTIK_PASS=<< COMPLETAR: contraseña API RouterOS >>
MIKROTIK_LISTA_MOROSOS=morosos

# ── Email (nodemailer — facturación automática) ───────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=<< COMPLETAR: ej. facturacion@acrnetworks.do >>
SMTP_PASS=<< COMPLETAR: App Password de Gmail (16 caracteres sin espacios) >>

# ── Sentry (opcional — error tracking en producción) ─────────────────────────
# SENTRY_DSN=<< COMPLETAR: https://xxx@oXXX.ingest.sentry.io/xxx >>

# ── Anti-tamper QR (HMAC simétrico) ──────────────────────────────────────────
# Secret server-only para HMAC-SHA256 del verifyHash. Validación requiere
# llamar al server. Si lo cambias, las firmas viejas dejan de verificar.
# NO ROTAR salvo compromiso real (rompe PDFs ya emitidos).
VERIFY_SECRET=<< COMPLETAR: 48+ bytes base64url >>

# ── Anti-tamper QR (Ed25519 asimétrico — mejora #7) ──────────────────────────
# Par de claves Ed25519 raw base64. Generar UNA VEZ con:
#   node -e "console.log(require('./shared/services/ed25519-sign.service').generateNewKeyPair())"
# PRIVATE en .env del server. PUBLIC se expone vía /api/publico/verify/public-key.
SIGN_ED25519_PRIVATE=<< COMPLETAR: 32 bytes base64 (44 chars con padding) >>
SIGN_ED25519_PUBLIC=<< COMPLETAR: 32 bytes base64 (44 chars con padding) >>

# ── Audit hash-chain (AuditCaja + AuditLog + CotizacionEvento + MovInv) ──────
# Secret HMAC para cadenas append-only anti-tamper. Mínimo 32 chars.
# NO ROTAR salvo compromiso real (rompe verifyChain de filas históricas).
AUDIT_SECRET=<< COMPLETAR: 48+ bytes base64url, distinto de VERIFY_SECRET >>

# ── Vault PAM (AES-256-GCM cifrado credenciales CRM) ─────────────────────────
# Llave de 32 bytes hex (64 chars). NO reutilizar con otros secrets.
VAULT_KEY=<< COMPLETAR: 64 chars hex — node -e "console.log(require('crypto').randomBytes(32).toString('hex'))" >>

# ── Redis (opcional — idempotency cross-process #18) ─────────────────────────
# REDIS_URL=redis://default:password@host:port

# ── Owner Alerts webhook (opcional — mejora #5) ──────────────────────────────
# Si configurado, las alertas owner se POSTean al webhook con HMAC signature.
# OWNER_ALERT_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
# OWNER_ALERT_WEBHOOK_SECRET=<< COMPLETAR: 32 bytes base64url para HMAC del payload >>
# OWNER_ALERT_DESCUENTO_PCT=20

# ── Health endpoint detallado ────────────────────────────────────────────────
# HEALTH_TOKEN=<< COMPLETAR: opcional, requerido para /api/health/detailed >>
