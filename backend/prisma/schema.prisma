generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum TipoAsistencia {
  Entrada
  Salida
}

enum TipoMovimiento {
  Entrada
  Salida
}

enum TipoServicio {
  WISP
  CCTV
  Redes
  CercoElectrico
  VentaDirecta
  Mixto
  SoporteTecnico
  Reparacion
  ProyectoCCTV
}

enum EstadoServicio {
  Pendiente
  EnInstalacion
  Activo
  Suspendido
  Cancelado
}

enum TipoOrden {
  Instalacion
  Retiro
  ServicioTecnico
  Mantenimiento
}

enum TipoFacturacion {
  Recurrente
  VentaUnica
  Servicio
}

enum EstadoFactura {
  Borrador
  Emitida
  Pagada
  Vencida
  Anulada
}

enum TipoItem {
  ARTICULO
  SERVICIO
}

enum EstadoTicketTaller {
  Recibido
  Diagnostico
  EsperandoPieza
  Listo
  Entregado
  Cancelado
}

enum TipoCredencial {
  Router
  Switch
  AccessPoint
  NVR
  DVR
  Camara
  Server
  Firewall
  ControlAcceso
  Otro
}

// ─── RRHH ─────────────────────────────────────────────────────────────────────

model Rol {
  id          Int        @id @default(autoincrement())
  nombre      String     @unique
  descripcion String?
  permisos    Json       @default("[]")
  nivel       Int        @default(0)
  activo      Boolean    @default(true)
  require2FA  Boolean    @default(false)
  empleados   Empleado[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([activo])
  @@index([nombre])
  @@index([nivel])
}

model Empleado {
  id                  Int                        @id @default(autoincrement())
  nombre              String
  cargo               String
  email               String                     @unique
  passwordHash        String                     @default("")
  bloqueado           Boolean                    @default(false)
  permisosExtra       Json                       @default("[]")
  twoFactorSecret     String?
  twoFactorEnabled    Boolean                    @default(false)
  // Hashes bcrypt de 8 códigos de respaldo TOTP (un-solo-uso). Si pierde el
  // dispositivo TOTP, ingresa uno y se elimina del array. Se generan al
  // habilitar 2FA y se muestran UNA SOLA VEZ en plano al user.
  backupCodes         Json                       @default("[]")
  creadoEn            DateTime                   @default(now())
  deletedAt           DateTime?
  asistencias         Asistencia[]
  ordenes             OrdenInstalacion[]
  ordenesTrabajo      OrdenTrabajo[]
  sessions            SessionToken[]
  fingerprints        DeviceFingerprint[]
  roles               Rol[]
  carritoTemp         CarritoTemp?
  ticketsTaller       TicketTaller[]
  fotosOT             OrdenFoto[]
  incidencias         IncidenciaReconciliacion[]
  timelineEvents      ActivoTimeline[]
  facturas            Factura[]
  webauthnCredentials WebAuthnCredential[]
  // DGII Fase 3 — relaciones inversas
  compras             Compra[]
  reportesDgii        ReporteDGIIGenerado[]

  @@index([nombre])
  @@index([deletedAt])
}

// Credenciales WebAuthn (passkeys) por empleado. Pensado primariamente para
// sistema:owner como reemplazo phishing-resistant del TOTP. Multi-credential
// permite registrar laptop + móvil + YubiKey: cualquiera completa el login.
model WebAuthnCredential {
  id             String    @id @default(uuid())
  empleadoId     Int
  // Base64URL del rawId que retorna el authenticator (la authenticator-side ID).
  credentialId   String    @unique
  // Base64URL de la public key COSE encoded (verificada en cada assertion).
  publicKey      String
  // Counter monotónico — replay-protection. Si recibimos counter ≤ almacenado,
  // sospechamos clon del credencial y rechazamos el login.
  counter        BigInt    @default(0)
  // Transports posibles ('usb', 'nfc', 'ble', 'internal', 'hybrid').
  transports     String[]  @default([])
  // Friendly name editable por el user ("MacBook Touch ID", "YubiKey azul").
  deviceName     String?
  // Backup eligibility: passkey replicable cross-device (iCloud, Bitwarden, 1Password).
  backupEligible Boolean   @default(false)
  createdAt      DateTime  @default(now())
  lastUsedAt     DateTime?
  empleado       Empleado  @relation(fields: [empleadoId], references: [id], onDelete: Cascade)

  @@index([empleadoId])
  @@index([lastUsedAt])
}

model SessionToken {
  id         String   @id @default(uuid())
  jti        String   @unique
  empleadoId Int
  userAgent  String   @default("")
  ip         String?
  // Hash sha256 de (UA + IP /24 + Accept-Language). Vincula la sesión con un
  // dispositivo conocido para facilitar UX (mismo device = no spammear "device
  // desconocido"). Null en sesiones legacy.
  deviceHash String?
  empleado   Empleado @relation(fields: [empleadoId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  expiresAt  DateTime

  @@index([empleadoId])
  @@index([jti])
  @@index([deviceHash])
}

// Dispositivos reconocidos por empleado. La PRIMERA vez que un (empleadoId, hash)
// se ve -> nuevo device, dispara alerta "Inicio desde dispositivo desconocido".
// Las siguientes -> renueva ultimoLogin.
model DeviceFingerprint {
  id          Int      @id @default(autoincrement())
  empleadoId  Int
  hash        String
  label       String? // Ej: "Chrome en Windows 11 · 192.168.1.x"
  ip          String?
  userAgent   String?
  primerLogin DateTime @default(now())
  ultimoLogin DateTime @default(now())
  empleado    Empleado @relation(fields: [empleadoId], references: [id], onDelete: Cascade)

  @@unique([empleadoId, hash])
  @@index([empleadoId])
  @@index([ultimoLogin])
}

model Asistencia {
  id         Int            @id @default(autoincrement())
  empleadoId Int
  fechaHora  DateTime       @default(now())
  tipo       TipoAsistencia
  latitud    String?
  longitud   String?
  empleado   Empleado       @relation(fields: [empleadoId], references: [id], onDelete: Cascade)

  @@index([empleadoId])
}

// ─── Inventario ───────────────────────────────────────────────────────────────

model Categoria {
  id        Int        @id @default(autoincrement())
  nombre    String     @unique
  productos Producto[]
}

model Producto {
  id               Int                      @id @default(autoincrement())
  sku              String                   @unique
  nombre           String
  // Descripción rica (admite Markdown ligero — se renderiza en POS detail + PDF).
  descripcion      String?
  // URL de imagen (Supabase Storage). Si presente, sustituye el ícono genérico en el POS.
  imagenUrl        String?
  precio           Decimal                  @db.Decimal(12, 2)
  // Costo promedio ponderado: se actualiza en cada entrada con
  // (stockActual*costoPromedio + entrada*costoNuevo) / (stockActual+entrada).
  costoPromedio    Decimal                  @default(0) @db.Decimal(12, 2)
  stockActual      Int                      @default(0)
  stockMinimo      Int                      @default(5)
  categoriaId      Int
  tipoItem         TipoItem                 @default(ARTICULO)
  esCanibalizado   Boolean                  @default(false)
  categoria        Categoria                @relation(fields: [categoriaId], references: [id], onDelete: Restrict)
  movimientos      MovimientoInventario[]
  plantillaEquipos PlantillaEquipo[]
  detallesOrden    DetalleOrden[]
  lineasOrden      LineaOrdenTrabajo[]
  lineasFactura    LineaFactura[]
  lineasCarrito    LineaCarrito[]
  activosCliente   ActivoCliente[]
  prestamos        EquipoPrestamo[]
  itemsCatalogo    ItemCatalogo[] // ItemCatalogos que apuntan a este Producto físico
  series           ProductoSerial[]
  bundlesPadre     ProductoBundle[]         @relation("BundlePadre")
  bundlesHijo      ProductoBundle[]         @relation("BundleHijo")
  reservas         ReservaInventario[]
  componentesDe    ItemCatalogoComponente[]

  @@index([sku])
  @@index([categoriaId])
  @@index([nombre])
  @@index([stockActual])
  @@index([tipoItem])
  @@index([esCanibalizado])
}

model MovimientoInventario {
  id                 Int               @id @default(autoincrement())
  productoId         Int
  tipo               TipoMovimiento
  cantidad           Int
  fecha              DateTime          @default(now())
  ordenInstalacionId String?
  producto           Producto          @relation(fields: [productoId], references: [id], onDelete: Cascade)
  orden              OrdenInstalacion? @relation(fields: [ordenInstalacionId], references: [id], onDelete: SetNull)
  prestamoSalida     EquipoPrestamo?   @relation("PrestamoSalida")
  prestamoEntrada    EquipoPrestamo?   @relation("PrestamoEntrada")
  // Mejora #2 — Hash-chain inmutable por producto. prevHash es el hash del
  // movimiento anterior del MISMO productoId (ordered por id asc). hash =
  // HMAC-SHA256(AUDIT_SECRET, canonical(snapshot) + prevHash). Filas legacy
  // (creadas antes de la migración) pueden tener ambos NULL — se ignoran al
  // verificar la cadena. Nuevas inserciones DEBEN llenarlos via el servicio
  // shared/services/movimiento-inventario.service.js.
  prevHash           String?
  hash               String?

  @@index([productoId])
  @@index([ordenInstalacionId])
  @@index([fecha])
  @@index([productoId, fecha])
  @@index([productoId, id])
  @@index([hash])
  @@index([prevHash])
}

// ─── Catálogo de Servicios ────────────────────────────────────────────────────

model Plan {
  id                String            @id @default(uuid())
  // SKU auto-generado vía generarSiguienteCodigo('plan') — visible al cliente
  // y al equipo de ventas para referencia rápida en cotizaciones B2B.
  sku               String?           @unique
  nombre            String
  tipo              TipoServicio
  precioMensualBase Decimal           @default(0) @db.Decimal(12, 2)
  precioInstalBase  Decimal           @default(0) @db.Decimal(12, 2)
  activo            Boolean           @default(true)
  plantillaEquipos  PlantillaEquipo[]
  servicios         Servicio[]
  // Mejora #15: relación inversa con ItemCatalogo. Cuando un ítem del
  // catálogo apunta a un Plan, al facturarlo el POS auto-crea un Servicio
  // activo para el cliente (precio + plan derivados del catálogo).
  itemsCatalogo     ItemCatalogo[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([tipo])
  @@index([activo])
  @@index([nombre])
  @@index([createdAt])
  @@index([sku])
}

model PlantillaEquipo {
  id         Int      @id @default(autoincrement())
  planId     String
  productoId Int
  cantidad   Int
  plan       Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  producto   Producto @relation(fields: [productoId], references: [id], onDelete: Restrict)

  @@unique([planId, productoId])
  @@index([planId])
  @@index([productoId])
}

// ─── Clientes ─────────────────────────────────────────────────────────────────

model Cliente {
  id                  String              @id @default(uuid())
  noCliente           String              @unique
  razonSocial         String
  nombreComercial     String?
  rnc                 String?             @unique
  registroMercantil   String?
  tipoEmpresa         String
  fechaInicio         DateTime            @default(now())
  nombreContacto      String
  apellidoContacto    String?
  cedula              String?
  cargo               String?
  direccion           String
  sector              String
  provincia           String
  latitud             String?
  longitud            String?
  telefonoPrincipal   String
  telefonoAlternativo String?
  email               String
  website             String?
  tipoCliente         String
  itbis               Boolean             @default(true)
  promHorasMes        Int?
  activo              Boolean             @default(true)
  fechaInactivo       DateTime?
  deletedAt           DateTime?
  limiteCredito       Decimal             @default(0.00) @db.Decimal(12, 2)
  diasCredito         Int                 @default(0)
  tipoNcf             String              @default("Consumidor Final")
  servicios           Servicio[]
  ordenesTrabajo      OrdenTrabajo[]
  facturas            Factura[]
  carritosTemp        CarritoTemp[]
  usuariosPortal      UsuarioPortal[]
  ticketsTaller       TicketTaller[]
  credenciales        CredencialCliente[]
  activosCliente      ActivoCliente[]
  prestamos           EquipoPrestamo[]
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  passwordHash String? @default("")

  @@index([noCliente])
  @@index([rnc])
  @@index([activo])
  @@index([razonSocial])
  @@index([createdAt])
  @@index([email])
}

// ─── Portal ───────────────────────────────────────────────────────────────────

model UsuarioPortal {
  id           String   @id @default(uuid())
  noUsuario    String   @unique
  nombre       String
  email        String   @unique
  passwordHash String
  telefono     String?
  activo       Boolean  @default(true)
  clienteId    String?
  cliente      Cliente? @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([email])
  @@index([clienteId])
}

model PortalSettings {
  id               Int      @id @default(1)
  mostrarEquipos   Boolean  @default(false)
  permitirPagos    Boolean  @default(false)
  mostrarMapa      Boolean  @default(true)
  mostrarCotizador Boolean  @default(true)
  mostrarServicios Boolean  @default(true)
  updatedAt        DateTime @updatedAt
}

// ─── Servicios ────────────────────────────────────────────────────────────────

model Servicio {
  id                   String             @id @default(uuid())
  noServicio           String?            @unique
  clienteId            String
  planId               String
  estado               EstadoServicio     @default(Pendiente)
  precioMensual        Decimal            @default(0) @db.Decimal(12, 2)
  precioInstalacion    Decimal            @default(0) @db.Decimal(12, 2)
  notasTecnicas        String?
  direccionInstalacion String?
  latitud              String?
  longitud             String?
  // Centralización de multimedia (single source of truth): la imagen vive
  // aquí cuando el ítem de Catálogo es un servicio puro (sin productoId).
  // El PanelCatalogo lee este campo en vez de duplicar el archivo.
  imagenUrl            String?
  cliente              Cliente            @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  plan                 Plan               @relation(fields: [planId], references: [id], onDelete: Restrict)
  ordenes              OrdenInstalacion[]
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([clienteId])
  @@index([planId])
  @@index([estado])
  @@index([createdAt])
}

// ─── Órdenes de Instalación ───────────────────────────────────────────────────

model OrdenInstalacion {
  id           String                 @id @default(uuid())
  servicioId   String
  tipo         TipoOrden
  estado       String                 @default("Pendiente")
  tecnicoId    Int
  notas        String?
  diagnostico  String?
  solucion     String?
  garantiaDias Int?
  completadaEn DateTime?
  servicio     Servicio               @relation(fields: [servicioId], references: [id], onDelete: Restrict)
  tecnico      Empleado               @relation(fields: [tecnicoId], references: [id], onDelete: Restrict)
  detalles     DetalleOrden[]
  movimientos  MovimientoInventario[]
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  @@index([servicioId])
  @@index([tecnicoId])
  @@index([estado])
  @@index([createdAt])
}

model DetalleOrden {
  id         Int              @id @default(autoincrement())
  ordenId    String
  productoId Int
  cantidad   Int
  orden      OrdenInstalacion @relation(fields: [ordenId], references: [id], onDelete: Cascade)
  producto   Producto         @relation(fields: [productoId], references: [id], onDelete: Restrict)

  @@unique([ordenId, productoId])
  @@index([ordenId])
  @@index([productoId])
}

// ─── Suplidores ───────────────────────────────────────────────────────────────

model Suplidor {
  id                String    @id @default(uuid())
  noSuplidor        String    @unique
  razonSocial       String
  nombreComercial   String?
  rnc               String?   @unique
  direccion         String
  sector            String
  provincia         String
  latitud           String?
  longitud          String?
  nombreContacto    String
  cedula            String?
  cargo             String?
  telefonoPrincipal String
  telefonoAlt       String?
  email             String?
  contactoAlt       String?
  actividad         String
  camposUsuario     String?
  fechaInicio       DateTime  @default(now())
  activo            Boolean   @default(true)
  fechaInactivo     DateTime?
  limiteCredito     Decimal   @default(0.00) @db.Decimal(12, 2)
  diasCredito       Int       @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  // DGII Fase 3 — compras (feed del 606)
  compras           Compra[]

  @@index([rnc])
  @@index([activo])
}

// ─── Audit Log ───────────────────────────────────────────────────────────────

model AuditLog {
  id        Int      @id @default(autoincrement())
  evento    String
  usuarioId Int?
  userName  String?
  ip        String?
  ua        String?
  meta      Json?
  creadoEn  DateTime @default(now())
  // Hash chain inmutable: prevHash = hash de la fila previa en orden por id;
  // hash = HMAC-SHA256(canonical(payload) + prevHash) con AUDIT_SECRET.
  // Garantía: alterar/borrar fila rompe la cadena verificable en
  // /api/auditoria/log/verify. Filas legacy con hash=null se ignoran.
  prevHash  String?
  hash      String?

  @@index([usuarioId])
  @@index([evento])
  @@index([creadoEn])
  @@index([usuarioId, creadoEn])
}

// ─── Prospectos ───────────────────────────────────────────────────────────────

model Prospecto {
  id                 String   @id @default(uuid())
  nombre             String
  telefono           String
  servicioInteresado String
  origen             String   @default("WhatsApp")
  notas              String?
  latitud            String?
  longitud           String?
  estado             String   @default("Nuevo")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([estado])
}

// ─── Ventas & Facturación ─────────────────────────────────────────────────────

model ItemCatalogo {
  id          String                   @id @default(uuid())
  // Código corto autogenerado (SRV-0001, ART-0001, REC-0001). Derivado del
  // tipo + nextval de secuencia. Visible en POS y PDF como identificador
  // humano-friendly cuando el item NO está vinculado a un Producto físico (SKU).
  codigo      String?                  @unique
  nombre      String
  descripcion String?
  // URL de imagen (Supabase Storage). Si está atado a un Producto físico,
  // el POS prioriza la imagen del Producto cuando exista (single source of truth).
  imagenUrl   String?
  tipo        TipoFacturacion
  categoria   TipoServicio
  precio      Decimal                  @db.Decimal(12, 2)
  costo       Decimal                  @default(0) @db.Decimal(12, 2)
  // stock manual (legacy). Si productoId está seteado, el stock real se lee
  // del Producto (sincronización: el catálogo refleja el inventario físico).
  stock       Int?
  // Vínculo opcional con Producto físico. Cuando existe, ItemCatalogo es la
  // "vitrina comercial" y Producto es la "fuente fiscal" de stock.
  productoId  Int?
  producto    Producto?                @relation(fields: [productoId], references: [id], onDelete: SetNull)
  // Mejora #15: vínculo opcional con Plan ISP. Cuando existe, al facturar
  // este ítem en POS, el backend auto-crea un Servicio activo para el
  // cliente con precio derivado del Plan. precioMensual y precioInstalacion
  // heredan plan.precioMensualBase / plan.precioInstalBase. Single source.
  planId      String?
  plan        Plan?                    @relation(fields: [planId], references: [id], onDelete: SetNull)
  activo      Boolean                  @default(true)
  tipoItem    TipoItem                 @default(SERVICIO)
  // Si el item es bundle (kit), `esBundle=true` activa la receta. Al facturar,
  // los descuentos de stock ocurren sobre cada componente, no sobre `productoId`.
  esBundle    Boolean                  @default(false)
  lineas      LineaOrdenTrabajo[]
  componentes ItemCatalogoComponente[]
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  @@index([tipo])
  @@index([categoria])
  @@index([activo])
  @@index([tipoItem])
  @@index([esBundle])
  @@index([productoId])
}

model OrdenTrabajo {
  id                  String              @id @default(uuid())
  noOT                String?             @unique
  clienteId           String
  tecnicoId           Int?
  tipoOT              String              @default("General")
  estado              String              @default("Pendiente")
  notasTecnicas       String?
  metadatos           Json                @default("{}")
  latitud             String?
  longitud            String?
  macAddress          String?
  ipAsignada          String?
  diaCorte            Int?
  garantiaDias        Int?
  completadaEn        DateTime?
  estaFacturada       Boolean             @default(false)
  fotosRequeridas     Int                 @default(0)
  limpiezaRealizada   Boolean             @default(false)
  fechaVencimientoSLA DateTime?
  deletedAt           DateTime?
  cliente             Cliente             @relation(fields: [clienteId], references: [id], onDelete: Restrict)
  tecnico             Empleado?           @relation(fields: [tecnicoId], references: [id], onDelete: SetNull)
  lineas              LineaOrdenTrabajo[]
  facturas            Factura[]
  activos             ActivoCliente[]
  fotos               OrdenFoto[]
  timeline            ActivoTimeline[]
  reservas            ReservaInventario[]
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([clienteId])
  @@index([tecnicoId])
  @@index([tipoOT])
  @@index([estado])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([fechaVencimientoSLA])
}

model LineaOrdenTrabajo {
  id             Int           @id @default(autoincrement())
  ordenId        String
  itemCatalogoId String?
  productoId     Int?
  descripcion    String
  cantidad       Int           @default(1)
  precioUnitario Decimal       @db.Decimal(12, 2)
  // Línea de "consumo interno": descuenta stock del Kardex al cerrar la OT
  // PERO no se factura al cliente (separación cobro/instalación). Ej: 15m
  // cable + 1 conector consumidos en una instalación WISP cuyo cobro al
  // cliente es solo el plan mensual.
  consumoInterno Boolean       @default(false)
  orden          OrdenTrabajo  @relation(fields: [ordenId], references: [id], onDelete: Cascade)
  itemCatalogo   ItemCatalogo? @relation(fields: [itemCatalogoId], references: [id], onDelete: SetNull)
  producto       Producto?     @relation(fields: [productoId], references: [id], onDelete: Restrict)

  @@index([ordenId])
  @@index([itemCatalogoId])
  @@index([productoId])
  @@index([consumoInterno])
}

model Factura {
  id                       String         @id @default(uuid())
  noFactura                String         @unique
  clienteId                String
  ordenId                  String?
  // ─── Nota de Crédito DGII B04 ────────────────────────────────────────────
  // facturaOrigenId: self-relation. Cuando esta fila ES una nota de crédito,
  // apunta a la Factura que está modificando (la "factura origen"). El PDF
  // imprime "Modifica al Comprobante: <NCF origen>" debajo del cliente, y la
  // factura origen queda con estado=Anulada (full reversal). Permitimos N
  // notasCredito por factura origen (DGII admite notas parciales) — no es
  // unique a propósito.
  facturaOrigenId          String?
  facturaOrigen            Factura?       @relation("NotaCreditoOrigen", fields: [facturaOrigenId], references: [id], onDelete: SetNull)
  notasCredito             Factura[]      @relation("NotaCreditoOrigen")
  esNotaCredito            Boolean        @default(false)
  // Nota de Débito (DGII B03): cobro adicional contra una factura emitida
  // (penalidades, intereses por mora, ajustes de precio al alza). NO restaura
  // inventario y NO anula la factura origen — solo se vincula vía
  // facturaOrigenId y registra el monto a cobrar.
  esNotaDebito             Boolean        @default(false)
  // Motivo libre exigido al emitir NC (B04) o ND (B03). Min 10 chars en backend.
  // Renombrado desde motivoNotaCredito para servir a ambos comprobantes
  // modificatorios (single source of truth en el PDF "Motivo: ...").
  motivoNotaModificatoria  String?
  estado                   EstadoFactura  @default(Borrador)
  subtotal                 Decimal        @db.Decimal(12, 2)
  itbis                    Decimal        @default(0) @db.Decimal(12, 2)
  total                    Decimal        @db.Decimal(12, 2)
  ncf                      String?
  tipoNcf                  String         @default("Consumidor Final")
  fechaEmision             DateTime       @default(now())
  fechaVence               DateTime?
  fechaPago                DateTime?
  notas                    String?
  // Override de condiciones comerciales por documento (opcional).
  // Si null/empty, el PDF usa EmpresaPerfil.condicionesDefault.
  // Shape: { validez, pago, entrega, garantia }
  condiciones              Json?
  // URL pública del PDF cacheado en Supabase Storage. Null = nunca generado o
  // invalidado (factura editada). Cuando existe, /pdf hace redirect 302 — cero CPU.
  pdfUrl                   String?
  // Desglose de cobro mixto. Shape: [{ metodo: 'Efectivo'|'Transferencia'|'Tarjeta'|'Cheque', monto: number, refer: string? }]
  // Suma debe igualar total (validado en POST). Null = no se desglosó (factura legacy).
  pagos                    Json?
  // ─── DGII Fase 3 — campos requeridos para el reporte 607 ──────────────────
  // tipoIngreso: catálogo DGII 01-08 (01=Operaciones, 02=Financieros, 03=Extra-
  // ordinarios, 04=Arrendamientos, 05=VentaActivos, 06=Otros, 07=ServiciosProf,
  // 08=Comisiones). Default 01 cubre 95% de las ventas ACR (servicios ISP/CCTV).
  tipoIngreso              String         @default("01")
  // Solo se llena cuando el cliente retiene impuestos al pagar (régimen DGII
  // "Agente de Retención") — se reporta la fecha en que aplicó la retención.
  fechaRetencion           DateTime?
  // Cuando un cliente retiene ITBIS o ISR al pagar, se almacena el monto en
  // estos campos. Default 0 — facturas legacy quedan en cero sin romper.
  itbisRetenidoTercero     Decimal        @default(0) @db.Decimal(12, 2)
  itbisPercibido           Decimal        @default(0) @db.Decimal(12, 2)
  retencionRentaTercero    Decimal        @default(0) @db.Decimal(12, 2)
  isrPercibido             Decimal        @default(0) @db.Decimal(12, 2)
  impuestoSelectivoConsumo Decimal        @default(0) @db.Decimal(12, 2)
  otrosImpuestos           Decimal        @default(0) @db.Decimal(12, 2)
  propinaLegal             Decimal        @default(0) @db.Decimal(12, 2)
  // Snapshot fiscal inmutable: foto del estado de la factura al momento de
  // emitirse (empresa.razonSocial, empresa.rnc, empresa.assets, cliente.*,
  // items con SKU/precio/descripcion del momento). Si la empresa cambia de
  // logo o nombre años después, los PDFs antiguos siguen mostrando los datos
  // que existían al emitirse. Cumplimiento DGII a largo plazo.
  // Null para cotizaciones (no fiscal) y facturas pre-rollout.
  snapshot                 Json?
  esCotizacion             Boolean        @default(false)
  // Etapa del pipeline Kanban para cotizaciones:
  // Borrador → Enviada → Negociacion → Aceptada → Convertida → Perdida
  // Facturas reales (esCotizacion=false) lo mantienen en 'Convertida'.
  etapaPipeline            String         @default("Borrador")
  deletedAt                DateTime?
  // Empleado que originó el documento. Necesario para RBAC Kanban
  // (cajero solo mueve cotizaciones propias) y trazabilidad fiscal.
  empleadoId               Int?
  // HMAC del contenido factura (rendered PDF) — permite verificación O(log n)
  // por hash indexado en lugar de buscar por noFactura ambiguo. Para validación
  // QR del PDF impreso o portal cliente.
  verifyHash               String?
  // Contador de intentos de render PDF fallidos. Cron lo usa para backoff
  // exponencial y abort a partir del 5to fallo (evita romper batch entero).
  pdfRenderAttempts        Int            @default(0)
  // M8: timestamp de la última invalidación del cache PDF. El cron compara este
  // valor pre/post render — si cambia mid-flight, descarta el render obsoleto.
  pdfInvalidatedAt         DateTime?
  cliente                  Cliente        @relation(fields: [clienteId], references: [id], onDelete: Restrict)
  orden                    OrdenTrabajo?  @relation(fields: [ordenId], references: [id], onDelete: SetNull)
  empleado                 Empleado?      @relation(fields: [empleadoId], references: [id], onDelete: SetNull)
  lineas                   LineaFactura[]
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt

  @@index([clienteId])
  @@index([ordenId])
  @@index([estado])
  @@index([fechaEmision])
  @@index([ncf])
  @@index([esCotizacion])
  @@index([noFactura])
  @@index([deletedAt])
  @@index([etapaPipeline])
  @@index([empleadoId])
  @@index([verifyHash])
  @@index([clienteId, estado])
  @@index([clienteId, fechaEmision])
  @@index([estado, fechaEmision])
  @@index([facturaOrigenId])
  @@index([esNotaCredito])
  @@index([esNotaDebito])
}

model LineaFactura {
  id                  Int       @id @default(autoincrement())
  facturaId           String
  productoId          Int?
  descripcion         String
