// ─── Mejora #5 — Owner God-Mode Alerts ───────────────────────────────────────
//
// Notificaciones críticas que se disparan ante eventos de alto impacto y se
// publican en el dashboard del owner via SSE + (opcional) webhook outbound
// firmado con HMAC para integrarse a Telegram / Discord / SMS / email.
//
// Tipos cubiertos (extensible):
//   - 'factura.anulada'      : factura DGII pasa a estado Anulada
//   - 'nc.emitida'           : Nota de Crédito B04 emitida
//   - 'nd.emitida'           : Nota de Débito B03 emitida
//   - 'precio.modificado'    : Producto.precio o ItemCatalogo.precio cambió
//   - 'descuento.alto'       : descuento PIN aplicado >= umbral (default 20%)
//   - 'stock.ajustado_manual': ajuste manual de stock fuera de venta/orden
//   - 'login.sospechoso'     : login desde nueva IP/UA + dispositivo no reconocido
//   - 'pin.bloqueado'        : rate-limit de PIN supervisor disparado
//
// Severity: 'info' | 'warn' | 'critical'. El front filtra por severity.
//
// `payload` JSONB libre: contiene snapshot del evento (resourceId, montos,
// before/after, motivo). NO incluir secretos / hashes / tokens.
//
// `ackBy` + `ackAt`: el owner marca alertas como leídas. Si NULL → unread.
model OwnerAlert {
  id              Int       @id @default(autoincrement())
  tipo            String
  severity        String    @default("warn")
  empleadoId      Int?
  empleadoNombre  String?
  // Referencia opcional al recurso afectado. Puede ser facturaId (UUID),
  // productoId (Int as string), etc. — interpretación por tipo.
  resourceType    String?
  resourceId      String?
  payload         Json
  ip              String?
  ua              String?
  createdAt       DateTime  @default(now())
  ackBy           Int?
  ackAt           DateTime?

  @@index([tipo])
  @@index([severity])
  @@index([createdAt])
  @@index([ackAt])
  @@index([tipo, createdAt])
}

// ─── Audit trail de caja: fraude interno + descuentos autorizados ────────────
model AuditCaja {
  id         Int      @id @default(autoincrement())
  tipo       String // 'venta' | 'anulacion' | 'descuento_pin' | 'descuento_rechazado'
  empleadoId Int?
  facturaId  String?
  monto      Decimal? @db.Decimal(12, 2)
  descPct    Decimal? @db.Decimal(5, 2) // % de descuento aplicado
  detalle    String?
  ip         String?
  ua         String?
  createdAt  DateTime @default(now())
  // Hash chain inmutable (anti-tamper). prevHash = hash de la fila anterior por
  // tipo+createdAt; hash = HMAC-SHA256(canonical(payload) + prevHash) firmado
  // con AUDIT_SECRET. Si alguien modifica/borra una fila, el chain queda roto
  // verificable via /api/auditoria/caja/verify.
  prevHash   String?
  hash       String?

  @@index([tipo])
  @@index([empleadoId])
  @@index([facturaId])
  @@index([createdAt])
  @@index([hash])
}

// ─── Mejora #4 — Hash-chain Cotizaciones ─────────────────────────────────────
//
// Cada cambio de estado o edición de una cotización (Factura con
// esCotizacion=true) genera una fila acá con snapshot canónico + hash-chain
// HMAC-SHA256 anclado al prevHash de la fila anterior de la MISMA cotización.
//
// Casos cubiertos:
//   - 'crear'   : primera fila al emitir cotización. prevHash=null, hash sobre snapshot inicial.
//   - 'editar'  : se modificó cualquier campo de la cotización pre-conversión.
//   - 'enviar'  : cajero la mandó al cliente (cambio etapaPipeline → 'Enviada').
//   - 'aceptar' : cliente confirmó (etapaPipeline → 'Aceptada').
//   - 'convertir' : conversión a factura real (etapaPipeline → 'Convertida').
//   - 'perder'  : etapaPipeline → 'Perdida'.
//
// Si alguien edita la fila Factura directamente con SQL, la cadena se rompe
// (siguiente verifyHashChain detecta el tampering). Auditor puede invocar
// GET /api/cotizaciones/:id/historial para validar la cadena.
model CotizacionEvento {
  id           Int      @id @default(autoincrement())
  cotizacionId String
  accion       String // 'crear' | 'editar' | 'enviar' | 'aceptar' | 'convertir' | 'perder'
  // Snapshot canónico del estado al momento de la acción. Incluye total +
  // lineas count + etapaPipeline + condiciones snapshot. JSON minified —
  // determinista para reproducir el hash.
  snapshot     Json
  // HMAC-SHA256(canonical(snapshot) + prevHash) firmado con AUDIT_SECRET.
  hash         String
  // Hash de la fila anterior de la MISMA cotizacionId (ordered por createdAt
  // ASC). Null en la primera fila (acción='crear').
  prevHash     String?
  empleadoId   Int?
  ip           String?
  ua           String?
  createdAt    DateTime @default(now())

  @@index([cotizacionId])
  @@index([cotizacionId, createdAt])
  @@index([accion])
  @@index([hash])
}

// ─── Trazabilidad serializada (CCTV, routers, NVR) ───────────────────────────
model ProductoSerial {
  id            Int       @id @default(autoincrement())
  productoId    Int
  serie         String
  estado        String    @default("Disponible") // Disponible|Vendido|RMA|Defectuoso|Reservado
  ubicacion     String?
  facturaId     String? // ref opcional a la factura donde se vendió
  garantiaHasta DateTime?
  producto      Producto  @relation(fields: [productoId], references: [id], onDelete: Cascade)
  notas         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([productoId, serie])
  @@index([estado])
  @@index([facturaId])
}

// ─── Reserva de stock al cotizar (TTL 72h por default) ───────────────────────
model ReservaInventario {
  id         Int           @id @default(autoincrement())
  productoId Int
  facturaId  String? // cotización asociada (opcional)
  ordenId    String? // OT que generó la reserva (opcional)
  cantidad   Int
  expiraEn   DateTime
  liberada   Boolean       @default(false)
  motivo     String?
  producto   Producto      @relation(fields: [productoId], references: [id], onDelete: Cascade)
  orden      OrdenTrabajo? @relation(fields: [ordenId], references: [id], onDelete: SetNull)
  createdAt  DateTime      @default(now())

  @@index([productoId])
  @@index([facturaId])
  @@index([ordenId])
  @@index([expiraEn])
  @@index([liberada])
}

// ─── BOM (Bill of Materials) — receta de bundles ─────────────────────────────
// Un ItemCatalogo marcado como bundle define N filas aquí, cada una apuntando
// a un Producto físico con la cantidad que se descuenta cuando se vende el item.
// Ej: "Kit CCTV 4 cámaras" → [{cámara, qty=4}, {DVR, qty=1}, {cable 50m, qty=1}]
model ItemCatalogoComponente {
  id             Int          @id @default(autoincrement())
  itemCatalogoId String
  productoId     Int
  cantidad       Int          @default(1)
  itemCatalogo   ItemCatalogo @relation(fields: [itemCatalogoId], references: [id], onDelete: Cascade)
  producto       Producto     @relation(fields: [productoId], references: [id], onDelete: Restrict)
  createdAt      DateTime     @default(now())

  @@unique([itemCatalogoId, productoId])
  @@index([itemCatalogoId])
  @@index([productoId])
}

// ─── Bundles para cross-sell en POS ──────────────────────────────────────────
model ProductoBundle {
  id        Int      @id @default(autoincrement())
  padreId   Int
  hijoId    Int
  score     Int      @default(1) // mayor = más relevante
  motivo    String?
  padre     Producto @relation("BundlePadre", fields: [padreId], references: [id], onDelete: Cascade)
  hijo      Producto @relation("BundleHijo", fields: [hijoId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([padreId, hijoId])
  @@index([padreId])
}

// ─── DGII Fase 3 — Compras (feed del reporte 606) ─────────────────────────────
//
// Una `Compra` representa una factura/NCF emitido por un proveedor (Suplidor)
// y registra todos los impuestos retenidos y categorías de gasto exigidas
// por la Norma DGII 06-2018 para el formato 606.
//
// Reglas:
//   - rnc/cedula viene del Suplidor — NO se duplica acá.
//   - ncfProveedor es OBLIGATORIO formato B##/E## + 10 dígitos (validado Zod).
//   - tipoBienServicio: catálogo 01-11 DGII (servicios, bienes, activos, etc.).
//   - formaPago: catálogo 01-07 DGII (efectivo, cheque, tarjeta, crédito...).
//   - Soft delete (deletedAt) — no se borra físicamente; el 606 ignora rows
//     con deletedAt != null pero la fila persiste 10 años por retención legal.
//   - Si ncfModificado != null, esta compra es una NC/ND emitida por el
//     proveedor que modifica el NCF apuntado (raro pero posible).
model Compra {
  id                       String    @id @default(uuid())
  noCompra                 String    @unique
  // suplidorId opcional: las compras informales (caja chica, gastos sin NCF)
  // pueden no tener Suplidor formal. NUNCA van al 606 — el filtro
  // esGastoInformal=true las excluye del reporte fiscal.
  suplidorId               String?
  // NCF emitido POR el proveedor. Opcional para gastos informales (sin
  // comprobante fiscal del proveedor — solo recibo o nota interna). Si
  // está presente DEBE ser B/E + 10 dígitos (validado Zod en service).
  ncfProveedor             String?
  // Solo se llena si el comprobante es ND/NC del proveedor modificando un
  // NCF anterior — entonces apunta al NCF original.
  ncfModificado            String?
  // Flag inmutable: si true, esta compra es un gasto informal (sin NCF
  // fiscal) y NO se reporta al 606. Sirve para flujo de caja real del
  // ERP (caja chica, propinas, viáticos, gastos cash). Default false
  // para que toda compra registrada antes de esta migración siga siendo
  // fiscalmente reportable.
  esGastoInformal          Boolean   @default(false)
  // Catálogo DGII 01-11. Ver PRD §5.1.1 para mapping ACR.
  tipoBienServicio         String
  fechaComprobante         DateTime
  fechaPago                DateTime?
  // Catálogo DGII 01-07. Ver PRD §5.1.2.
  formaPago                String
  // Desglose obligatorio para el 606. Default 0 en todos los campos opcionales
  // para no romper compras legacy ni forzar al user a llenar todo.
  montoServicios           Decimal   @default(0) @db.Decimal(12, 2)
  montoBienes              Decimal   @default(0) @db.Decimal(12, 2)
  itbisFacturado           Decimal   @default(0) @db.Decimal(12, 2)
  itbisRetenido            Decimal   @default(0) @db.Decimal(12, 2)
  itbisProporcionalidad    Decimal   @default(0) @db.Decimal(12, 2)
  itbisLlevadoCosto        Decimal   @default(0) @db.Decimal(12, 2)
  itbisPorAdelantar        Decimal   @default(0) @db.Decimal(12, 2)
  itbisPercibido           Decimal   @default(0) @db.Decimal(12, 2)
  // Catálogo DGII 01-07. Solo aplica si se retuvo ISR (ej. profesionales).
  tipoRetencionIsr         String?
  montoRetencionRenta      Decimal   @default(0) @db.Decimal(12, 2)
  isrPercibido             Decimal   @default(0) @db.Decimal(12, 2)
  impuestoSelectivoConsumo Decimal   @default(0) @db.Decimal(12, 2)
  otrosImpuestos           Decimal   @default(0) @db.Decimal(12, 2)
  propinaLegal             Decimal   @default(0) @db.Decimal(12, 2)
  notas                    String?
  empleadoId               Int?
  deletedAt                DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  suplidor                 Suplidor? @relation(fields: [suplidorId], references: [id], onDelete: Restrict)
  empleado                 Empleado? @relation(fields: [empleadoId], references: [id], onDelete: SetNull)

  @@index([suplidorId])
  @@index([ncfProveedor])
  @@index([fechaComprobante])
  @@index([deletedAt])
  @@index([suplidorId, fechaComprobante])
  @@index([tipoBienServicio])
  @@index([esGastoInformal])
}

// ─── DGII Fase 3 — Audit trail de reportes generados ─────────────────────────
//
// Cada generación de 606/607 deja una fila inmutable acá. SHA-256 del archivo
// generado permite probar a la DGII (o auditor) que el archivo entregado es
// idéntico al que el sistema produjo. archivoUrl apunta al bucket privado en
// Supabase Storage con retención 10 años (Norma DGII 06-2018 art. 7).
//
// La columna unique (tipo, periodo, rncEmpresa) permite re-generaciones (cada
// una nueva fila con SHA distinto pero MISMA periodo) — el unique se levantó
// porque la realidad es que un mes puede tener varias versiones (correcciones
// post-cierre). Audit-trail decide cuál fue el "oficialmente enviado".
model ReporteDGIIGenerado {
  id                String   @id @default(uuid())
  tipo              String // "606" | "607"
  periodo           String // "YYYYMM"
  rncEmpresa        String
  cantidadRegistros Int
  totalMonto        Decimal  @db.Decimal(14, 2)
  totalItbis        Decimal  @db.Decimal(14, 2)
  // Hash SHA-256 del contenido TXT (hex 64 chars). Cyber-Neo: prueba de
  // integridad inmutable post-facto.
  sha256            String
  // Path Supabase Storage `dgii/<rnc>/<periodo>/<tipo>-<timestamp>.txt`.
  archivoUrl        String?
  empleadoId        Int
  ipGeneracion      String?
  userAgent         String?
  generadoEn        DateTime @default(now())
  empleado          Empleado @relation(fields: [empleadoId], references: [id], onDelete: Restrict)

  @@index([tipo])
  @@index([periodo])
  @@index([generadoEn])
  @@index([tipo, periodo])
  @@index([rncEmpresa])
}
