  precioUnitario      Decimal   @db.Decimal(12, 2)
  descuentoPorcentaje Decimal   @default(0) @db.Decimal(5, 2)
  descuentoMonto      Decimal   @default(0) @db.Decimal(12, 2)
  // Mejora #6: soft-delete. Las líneas eliminadas al editar un Borrador
  // NO se borran físicamente — quedan con deletedAt seteado para preservar
  // audit-trail fiscal DGII (retención 10 años Norma 06-2018 art. 7).
  // Listados y PDFs filtran deletedAt: null. Facturas Emitida/Pagada nunca
  // tocan líneas (son inmutables).
  deletedAt           DateTime?
  factura             Factura   @relation(fields: [facturaId], references: [id], onDelete: Cascade)
  producto            Producto? @relation(fields: [productoId], references: [id], onDelete: Restrict)

  @@index([facturaId])
  @@index([productoId])
  @@index([deletedAt])
}

