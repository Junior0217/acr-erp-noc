generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum TipoAsistencia {
  Entrada
  Salida
}

enum TipoMovimiento {
  Entrada
  Salida
}

enum TipoServicio {
  WISP
  CCTV
  Redes
  CercoElectrico
  VentaDirecta
  Mixto
  SoporteTecnico
  Reparacion
  ProyectoCCTV
}

enum EstadoServicio {
  Pendiente
  EnInstalacion
  Activo
  Suspendido
  Cancelado
}

enum TipoOrden {
  Instalacion
  Retiro
  ServicioTecnico
  Mantenimiento
}

enum TipoFacturacion {
  Recurrente
  VentaUnica
  Servicio
}

enum EstadoFactura {
  Borrador
  Emitida
  Pagada
  Vencida
  Anulada
}

enum TipoItem {
  ARTICULO
  SERVICIO
}

enum EstadoTicketTaller {
  Recibido
  Diagnostico
  EsperandoPieza
  Listo
  Entregado
  Cancelado
}

enum TipoCredencial {
  Router
  Switch
  AccessPoint
  NVR
  DVR
  Camara
  Server
  Firewall
  ControlAcceso
  Otro
}

// ─── RRHH ─────────────────────────────────────────────────────────────────────

model Rol {
  id          Int        @id @default(autoincrement())
  nombre      String     @unique
  descripcion String?
  permisos    Json       @default("[]")
  nivel       Int        @default(0)
  activo      Boolean    @default(true)
  require2FA  Boolean    @default(false)
  empleados   Empleado[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([activo])
  @@index([nombre])
  @@index([nivel])
}

model Empleado {
  id                  Int                        @id @default(autoincrement())
  nombre              String
  cargo               String
  email               String                     @unique
  passwordHash        String                     @default("")
  bloqueado           Boolean                    @default(false)
  permisosExtra       Json                       @default("[]")
  twoFactorSecret     String?
  twoFactorEnabled    Boolean                    @default(false)
  // Hashes bcrypt de 8 códigos de respaldo TOTP (un-solo-uso). Si pierde el
  // dispositivo TOTP, ingresa uno y se elimina del array. Se generan al
  // habilitar 2FA y se muestran UNA SOLA VEZ en plano al user.
  backupCodes         Json                       @default("[]")
  creadoEn            DateTime                   @default(now())
  deletedAt           DateTime?
  asistencias         Asistencia[]
  ordenes             OrdenInstalacion[]
  ordenesTrabajo      OrdenTrabajo[]
  sessions            SessionToken[]
  fingerprints        DeviceFingerprint[]
  roles               Rol[]
  carritoTemp         CarritoTemp?
  ticketsTaller       TicketTaller[]
  fotosOT             OrdenFoto[]
  incidencias         IncidenciaReconciliacion[]
  timelineEvents      ActivoTimeline[]
  facturas            Factura[]
  webauthnCredentials WebAuthnCredential[]

  @@index([nombre])
  @@index([deletedAt])
}

// Credenciales WebAuthn (passkeys) por empleado. Pensado primariamente para
// sistema:owner como reemplazo phishing-resistant del TOTP. Multi-credential
// permite registrar laptop + móvil + YubiKey: cualquiera completa el login.
model WebAuthnCredential {
  id             String    @id @default(uuid())
  empleadoId     Int
  // Base64URL del rawId que retorna el authenticator (la authenticator-side ID).
  credentialId   String    @unique
  // Base64URL de la public key COSE encoded (verificada en cada assertion).
  publicKey      String
  // Counter monotónico — replay-protection. Si recibimos counter ≤ almacenado,
  // sospechamos clon del credencial y rechazamos el login.
  counter        BigInt    @default(0)
  // Transports posibles ('usb', 'nfc', 'ble', 'internal', 'hybrid').
  transports     String[]  @default([])
  // Friendly name editable por el user ("MacBook Touch ID", "YubiKey azul").
  deviceName     String?
  // Backup eligibility: passkey replicable cross-device (iCloud, Bitwarden, 1Password).
  backupEligible Boolean   @default(false)
  createdAt      DateTime  @default(now())
  lastUsedAt     DateTime?
  empleado       Empleado  @relation(fields: [empleadoId], references: [id], onDelete: Cascade)

  @@index([empleadoId])
  @@index([lastUsedAt])
}

model SessionToken {
  id         String   @id @default(uuid())
  jti        String   @unique
  empleadoId Int
  userAgent  String   @default("")
  ip         String?
  // Hash sha256 de (UA + IP /24 + Accept-Language). Vincula la sesión con un
  // dispositivo conocido para facilitar UX (mismo device = no spammear "device
  // desconocido"). Null en sesiones legacy.
  deviceHash String?
  empleado   Empleado @relation(fields: [empleadoId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  expiresAt  DateTime

  @@index([empleadoId])
  @@index([jti])
  @@index([deviceHash])
}

// Dispositivos reconocidos por empleado. La PRIMERA vez que un (empleadoId, hash)
// se ve -> nuevo device, dispara alerta "Inicio desde dispositivo desconocido".
// Las siguientes -> renueva ultimoLogin.
model DeviceFingerprint {
  id          Int      @id @default(autoincrement())
  empleadoId  Int
  hash        String
  label       String? // Ej: "Chrome en Windows 11 · 192.168.1.x"
  ip          String?
  userAgent   String?
  primerLogin DateTime @default(now())
  ultimoLogin DateTime @default(now())
  empleado    Empleado @relation(fields: [empleadoId], references: [id], onDelete: Cascade)

  @@unique([empleadoId, hash])
  @@index([empleadoId])
  @@index([ultimoLogin])
}

model Asistencia {
  id         Int            @id @default(autoincrement())
  empleadoId Int
  fechaHora  DateTime       @default(now())
  tipo       TipoAsistencia
  latitud    String?
  longitud   String?
  empleado   Empleado       @relation(fields: [empleadoId], references: [id], onDelete: Cascade)

  @@index([empleadoId])
}

// ─── Inventario ───────────────────────────────────────────────────────────────

model Categoria {
  id        Int        @id @default(autoincrement())
  nombre    String     @unique
  productos Producto[]
}

model Producto {
  id               Int                    @id @default(autoincrement())
  sku              String                 @unique
  nombre           String
  // Descripción rica (admite Markdown ligero — se renderiza en POS detail + PDF).
  descripcion      String?
  // URL de imagen (Supabase Storage). Si presente, sustituye el ícono genérico en el POS.
  imagenUrl        String?
  precio           Decimal                @db.Decimal(12, 2)
  // Costo promedio ponderado: se actualiza en cada entrada con
  // (stockActual*costoPromedio + entrada*costoNuevo) / (stockActual+entrada).
  costoPromedio    Decimal                @default(0) @db.Decimal(12, 2)
  stockActual      Int                    @default(0)
  stockMinimo      Int                    @default(5)
  categoriaId      Int
  tipoItem         TipoItem               @default(ARTICULO)
  esCanibalizado   Boolean                @default(false)
  categoria        Categoria              @relation(fields: [categoriaId], references: [id], onDelete: Restrict)
  movimientos      MovimientoInventario[]
  plantillaEquipos PlantillaEquipo[]
  detallesOrden    DetalleOrden[]
  lineasOrden      LineaOrdenTrabajo[]
  lineasFactura    LineaFactura[]
  lineasCarrito    LineaCarrito[]
  activosCliente   ActivoCliente[]
  prestamos        EquipoPrestamo[]
  itemsCatalogo    ItemCatalogo[] // ItemCatalogos que apuntan a este Producto físico
  series           ProductoSerial[]
  bundlesPadre     ProductoBundle[]       @relation("BundlePadre")
  bundlesHijo      ProductoBundle[]       @relation("BundleHijo")
  reservas         ReservaInventario[]

  @@index([sku])
  @@index([categoriaId])
  @@index([nombre])
  @@index([stockActual])
  @@index([tipoItem])
  @@index([esCanibalizado])
}

model MovimientoInventario {
  id                 Int               @id @default(autoincrement())
  productoId         Int
  tipo               TipoMovimiento
  cantidad           Int
  fecha              DateTime          @default(now())
  ordenInstalacionId String?
  producto           Producto          @relation(fields: [productoId], references: [id], onDelete: Cascade)
  orden              OrdenInstalacion? @relation(fields: [ordenInstalacionId], references: [id], onDelete: SetNull)
  prestamoSalida     EquipoPrestamo?   @relation("PrestamoSalida")
  prestamoEntrada    EquipoPrestamo?   @relation("PrestamoEntrada")

  @@index([productoId])
  @@index([ordenInstalacionId])
  @@index([fecha])
  @@index([productoId, fecha])
}

// ─── Catálogo de Servicios ────────────────────────────────────────────────────

model Plan {
  id                String            @id @default(uuid())
  nombre            String
  tipo              TipoServicio
  precioMensualBase Decimal           @default(0) @db.Decimal(12, 2)
  precioInstalBase  Decimal           @default(0) @db.Decimal(12, 2)
  activo            Boolean           @default(true)
  plantillaEquipos  PlantillaEquipo[]
  servicios         Servicio[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([tipo])
  @@index([activo])
  @@index([nombre])
  @@index([createdAt])
}

model PlantillaEquipo {
  id         Int      @id @default(autoincrement())
  planId     String
  productoId Int
  cantidad   Int
  plan       Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  producto   Producto @relation(fields: [productoId], references: [id], onDelete: Restrict)

  @@unique([planId, productoId])
  @@index([planId])
  @@index([productoId])
}

// ─── Clientes ─────────────────────────────────────────────────────────────────

model Cliente {
  id                  String              @id @default(uuid())
  noCliente           String              @unique
  razonSocial         String
  nombreComercial     String?
  rnc                 String?             @unique
  registroMercantil   String?
  tipoEmpresa         String
  fechaInicio         DateTime            @default(now())
  nombreContacto      String
  apellidoContacto    String?
  cedula              String?
  cargo               String?
  direccion           String
  sector              String
  provincia           String
  latitud             String?
  longitud            String?
  telefonoPrincipal   String
  telefonoAlternativo String?
  email               String
  website             String?
  tipoCliente         String
  itbis               Boolean             @default(true)
  promHorasMes        Int?
  activo              Boolean             @default(true)
  fechaInactivo       DateTime?
  deletedAt           DateTime?
  limiteCredito       Decimal             @default(0.00) @db.Decimal(12, 2)
  diasCredito         Int                 @default(0)
  tipoNcf             String              @default("Consumidor Final")
  servicios           Servicio[]
  ordenesTrabajo      OrdenTrabajo[]
  facturas            Factura[]
  carritosTemp        CarritoTemp[]
  usuariosPortal      UsuarioPortal[]
  ticketsTaller       TicketTaller[]
  credenciales        CredencialCliente[]
  activosCliente      ActivoCliente[]
  prestamos           EquipoPrestamo[]
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  passwordHash String? @default("")

  @@index([noCliente])
  @@index([rnc])
  @@index([activo])
  @@index([razonSocial])
  @@index([createdAt])
  @@index([email])
}

// ─── Portal ───────────────────────────────────────────────────────────────────

model UsuarioPortal {
  id           String   @id @default(uuid())
  noUsuario    String   @unique
  nombre       String
  email        String   @unique
  passwordHash String
  telefono     String?
  activo       Boolean  @default(true)
  clienteId    String?
  cliente      Cliente? @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([email])
  @@index([clienteId])
}

model PortalSettings {
  id               Int      @id @default(1)
  mostrarEquipos   Boolean  @default(false)
  permitirPagos    Boolean  @default(false)
  mostrarMapa      Boolean  @default(true)
  mostrarCotizador Boolean  @default(true)
  mostrarServicios Boolean  @default(true)
  updatedAt        DateTime @updatedAt
}

// ─── Servicios ────────────────────────────────────────────────────────────────

model Servicio {
  id                   String             @id @default(uuid())
  noServicio           String?            @unique
  clienteId            String
  planId               String
  estado               EstadoServicio     @default(Pendiente)
  precioMensual        Decimal            @default(0) @db.Decimal(12, 2)
  precioInstalacion    Decimal            @default(0) @db.Decimal(12, 2)
  notasTecnicas        String?
  direccionInstalacion String?
  latitud              String?
  longitud             String?
  cliente              Cliente            @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  plan                 Plan               @relation(fields: [planId], references: [id], onDelete: Restrict)
  ordenes              OrdenInstalacion[]
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([clienteId])
  @@index([planId])
  @@index([estado])
  @@index([createdAt])
}

// ─── Órdenes de Instalación ───────────────────────────────────────────────────

model OrdenInstalacion {
  id           String                 @id @default(uuid())
  servicioId   String
  tipo         TipoOrden
  estado       String                 @default("Pendiente")
  tecnicoId    Int
  notas        String?
  diagnostico  String?
  solucion     String?
  garantiaDias Int?
  completadaEn DateTime?
  servicio     Servicio               @relation(fields: [servicioId], references: [id], onDelete: Restrict)
  tecnico      Empleado               @relation(fields: [tecnicoId], references: [id], onDelete: Restrict)
  detalles     DetalleOrden[]
  movimientos  MovimientoInventario[]
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  @@index([servicioId])
  @@index([tecnicoId])
  @@index([estado])
  @@index([createdAt])
}

model DetalleOrden {
  id         Int              @id @default(autoincrement())
  ordenId    String
  productoId Int
  cantidad   Int
  orden      OrdenInstalacion @relation(fields: [ordenId], references: [id], onDelete: Cascade)
  producto   Producto         @relation(fields: [productoId], references: [id], onDelete: Restrict)

  @@unique([ordenId, productoId])
  @@index([ordenId])
  @@index([productoId])
}

// ─── Suplidores ───────────────────────────────────────────────────────────────

model Suplidor {
  id                String    @id @default(uuid())
  noSuplidor        String    @unique
  razonSocial       String
  nombreComercial   String?
  rnc               String?   @unique
  direccion         String
  sector            String
  provincia         String
  latitud           String?
  longitud          String?
  nombreContacto    String
  cedula            String?
  cargo             String?
  telefonoPrincipal String
  telefonoAlt       String?
  email             String?
  contactoAlt       String?
  actividad         String
  camposUsuario     String?
  fechaInicio       DateTime  @default(now())
  activo            Boolean   @default(true)
  fechaInactivo     DateTime?
  limiteCredito     Decimal   @default(0.00) @db.Decimal(12, 2)
  diasCredito       Int       @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([rnc])
  @@index([activo])
}

// ─── Audit Log ───────────────────────────────────────────────────────────────

model AuditLog {
  id        Int      @id @default(autoincrement())
  evento    String
  usuarioId Int?
  userName  String?
  ip        String?
  ua        String?
  meta      Json?
  creadoEn  DateTime @default(now())

  @@index([usuarioId])
  @@index([evento])
  @@index([creadoEn])
  @@index([usuarioId, creadoEn])
}

// ─── Prospectos ───────────────────────────────────────────────────────────────

model Prospecto {
  id                 String   @id @default(uuid())
  nombre             String
  telefono           String
  servicioInteresado String
  origen             String   @default("WhatsApp")
  notas              String?
  latitud            String?
  longitud           String?
  estado             String   @default("Nuevo")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([estado])
}

// ─── Ventas & Facturación ─────────────────────────────────────────────────────

model ItemCatalogo {
  id          String              @id @default(uuid())
  // Código corto autogenerado (SRV-0001, ART-0001, REC-0001). Derivado del
  // tipo + nextval de secuencia. Visible en POS y PDF como identificador
  // humano-friendly cuando el item NO está vinculado a un Producto físico (SKU).
  codigo      String?             @unique
  nombre      String
  descripcion String?
  // URL de imagen (Supabase Storage). Si está atado a un Producto físico,
  // el POS prioriza la imagen del Producto cuando exista (single source of truth).
  imagenUrl   String?
  tipo        TipoFacturacion
  categoria   TipoServicio
  precio      Decimal             @db.Decimal(12, 2)
  costo       Decimal             @default(0) @db.Decimal(12, 2)
  // stock manual (legacy). Si productoId está seteado, el stock real se lee
  // del Producto (sincronización: el catálogo refleja el inventario físico).
  stock       Int?
  // Vínculo opcional con Producto físico. Cuando existe, ItemCatalogo es la
  // "vitrina comercial" y Producto es la "fuente fiscal" de stock.
  productoId  Int?
  producto    Producto?           @relation(fields: [productoId], references: [id], onDelete: SetNull)
  activo      Boolean             @default(true)
  tipoItem    TipoItem            @default(SERVICIO)
  lineas      LineaOrdenTrabajo[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([tipo])
  @@index([categoria])
  @@index([activo])
  @@index([tipoItem])
  @@index([productoId])
}

model OrdenTrabajo {
  id                  String              @id @default(uuid())
  noOT                String?             @unique
  clienteId           String
  tecnicoId           Int?
  tipoOT              String              @default("General")
  estado              String              @default("Pendiente")
  notasTecnicas       String?
  metadatos           Json                @default("{}")
  latitud             String?
  longitud            String?
  macAddress          String?
  ipAsignada          String?
  diaCorte            Int?
  garantiaDias        Int?
  completadaEn        DateTime?
  estaFacturada       Boolean             @default(false)
  fotosRequeridas     Int                 @default(0)
  limpiezaRealizada   Boolean             @default(false)
  fechaVencimientoSLA DateTime?
  deletedAt           DateTime?
  cliente             Cliente             @relation(fields: [clienteId], references: [id], onDelete: Restrict)
  tecnico             Empleado?           @relation(fields: [tecnicoId], references: [id], onDelete: SetNull)
  lineas              LineaOrdenTrabajo[]
  facturas            Factura[]
  activos             ActivoCliente[]
  fotos               OrdenFoto[]
  timeline            ActivoTimeline[]
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([clienteId])
  @@index([tecnicoId])
  @@index([tipoOT])
  @@index([estado])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([fechaVencimientoSLA])
}

model LineaOrdenTrabajo {
  id             Int           @id @default(autoincrement())
  ordenId        String
  itemCatalogoId String?
  productoId     Int?
  descripcion    String
  cantidad       Int           @default(1)
  precioUnitario Decimal       @db.Decimal(12, 2)
  orden          OrdenTrabajo  @relation(fields: [ordenId], references: [id], onDelete: Cascade)
  itemCatalogo   ItemCatalogo? @relation(fields: [itemCatalogoId], references: [id], onDelete: SetNull)
  producto       Producto?     @relation(fields: [productoId], references: [id], onDelete: Restrict)

  @@index([ordenId])
  @@index([itemCatalogoId])
  @@index([productoId])
}

model Factura {
  id                String         @id @default(uuid())
  noFactura         String         @unique
  clienteId         String
  ordenId           String?
  estado            EstadoFactura  @default(Borrador)
  subtotal          Decimal        @db.Decimal(12, 2)
  itbis             Decimal        @default(0) @db.Decimal(12, 2)
  total             Decimal        @db.Decimal(12, 2)
  ncf               String?
  tipoNcf           String         @default("Consumidor Final")
  fechaEmision      DateTime       @default(now())
  fechaVence        DateTime?
  fechaPago         DateTime?
  notas             String?
  // Override de condiciones comerciales por documento (opcional).
  // Si null/empty, el PDF usa EmpresaPerfil.condicionesDefault.
  // Shape: { validez, pago, entrega, garantia }
  condiciones       Json?
  // URL pública del PDF cacheado en Supabase Storage. Null = nunca generado o
  // invalidado (factura editada). Cuando existe, /pdf hace redirect 302 — cero CPU.
  pdfUrl            String?
  // Desglose de cobro mixto. Shape: [{ metodo: 'Efectivo'|'Transferencia'|'Tarjeta'|'Cheque', monto: number, refer: string? }]
  // Suma debe igualar total (validado en POST). Null = no se desglosó (factura legacy).
  pagos             Json?
  // Snapshot fiscal inmutable: foto del estado de la factura al momento de
  // emitirse (empresa.razonSocial, empresa.rnc, empresa.assets, cliente.*,
  // items con SKU/precio/descripcion del momento). Si la empresa cambia de
  // logo o nombre años después, los PDFs antiguos siguen mostrando los datos
  // que existían al emitirse. Cumplimiento DGII a largo plazo.
  // Null para cotizaciones (no fiscal) y facturas pre-rollout.
  snapshot          Json?
  esCotizacion      Boolean        @default(false)
  // Etapa del pipeline Kanban para cotizaciones:
  // Borrador → Enviada → Negociacion → Aceptada → Convertida → Perdida
  // Facturas reales (esCotizacion=false) lo mantienen en 'Convertida'.
  etapaPipeline     String         @default("Borrador")
  deletedAt         DateTime?
  // Empleado que originó el documento. Necesario para RBAC Kanban
  // (cajero solo mueve cotizaciones propias) y trazabilidad fiscal.
  empleadoId        Int?
  // HMAC del contenido factura (rendered PDF) — permite verificación O(log n)
  // por hash indexado en lugar de buscar por noFactura ambiguo. Para validación
  // QR del PDF impreso o portal cliente.
  verifyHash        String?
  // Contador de intentos de render PDF fallidos. Cron lo usa para backoff
  // exponencial y abort a partir del 5to fallo (evita romper batch entero).
  pdfRenderAttempts Int            @default(0)
  // M8: timestamp de la última invalidación del cache PDF. El cron compara este
  // valor pre/post render — si cambia mid-flight, descarta el render obsoleto.
  pdfInvalidatedAt  DateTime?
  cliente           Cliente        @relation(fields: [clienteId], references: [id], onDelete: Restrict)
  orden             OrdenTrabajo?  @relation(fields: [ordenId], references: [id], onDelete: SetNull)
  empleado          Empleado?      @relation(fields: [empleadoId], references: [id], onDelete: SetNull)
  lineas            LineaFactura[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([clienteId])
  @@index([ordenId])
  @@index([estado])
  @@index([fechaEmision])
  @@index([ncf])
  @@index([esCotizacion])
  @@index([noFactura])
  @@index([deletedAt])
  @@index([etapaPipeline])
  @@index([empleadoId])
  @@index([verifyHash])
  @@index([clienteId, estado])
  @@index([clienteId, fechaEmision])
  @@index([estado, fechaEmision])
}

model LineaFactura {
  id                  Int       @id @default(autoincrement())
  facturaId           String
  productoId          Int?
  descripcion         String
  cantidad            Int
  precioUnitario      Decimal   @db.Decimal(12, 2)
  descuentoPorcentaje Decimal   @default(0) @db.Decimal(5, 2)
  descuentoMonto      Decimal   @default(0) @db.Decimal(12, 2)
  factura             Factura   @relation(fields: [facturaId], references: [id], onDelete: Cascade)
  producto            Producto? @relation(fields: [productoId], references: [id], onDelete: Restrict)

  @@index([facturaId])
  @@index([productoId])
}

model ConfiguracionNCF {
  id              Int       @id @default(autoincrement())
  prefijo         String
  tipoNcf         String    @unique
  tipoDescripcion String
  secuenciaActual Int       @default(0)
  limite          Int       @default(9999999)
  vencimiento     DateTime?
  activo          Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ─── Carrito Temporal (POS) ───────────────────────────────────────────────────

model CarritoTemp {
  id         String         @id @default(uuid())
  empleadoId Int            @unique
  clienteId  String?
  applyItbis Boolean        @default(false)
  diasVence  Int            @default(30)
  empleado   Empleado       @relation(fields: [empleadoId], references: [id], onDelete: Cascade)
  cliente    Cliente?       @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  lineas     LineaCarrito[]
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([empleadoId])
  @@index([clienteId])
}

model LineaCarrito {
  id                  Int         @id @default(autoincrement())
  carritoId           String
  productoId          Int
  cantidad            Int         @default(1)
  precioUnitario      Decimal     @db.Decimal(12, 2)
  descuentoPorcentaje Decimal     @default(0) @db.Decimal(5, 2)
  descuentoMonto      Decimal     @default(0) @db.Decimal(12, 2)
  carrito             CarritoTemp @relation(fields: [carritoId], references: [id], onDelete: Cascade)
  producto            Producto    @relation(fields: [productoId], references: [id], onDelete: Restrict)

  @@index([carritoId])
  @@index([productoId])
}

// ─── Singleton: Perfil legal y de contacto de la empresa ────────────────────

model EmpresaPerfil {
  id                    Int       @id @default(1)
  rnc                   String
  razonSocial           String
  nombreComercial       String?
  registroMercantil     String?
  representanteNombre   String?
  representanteApellido String?
  representanteCedula   String?
  representanteCargo    String?
  direccion             String?
  sector                String?
  provincia             String?
  pais                  String    @default("República Dominicana")
  tipoEmpresa           String?
  fechaInicio           DateTime?
  telefono              String?
  fax                   String?
  email                 String?
  website               String?
  assets                Json      @default("{}")
  eslogan               String?
  // Condiciones comerciales por defecto (cotizaciones/facturas).
  // Shape: { validez, pago, entrega, garantia, notasFooter }
  // Cada factura puede sobreescribirlas en Factura.condiciones.
  condicionesDefault    Json      @default("{}")
  // PIN del supervisor (4-8 dígitos). Requerido cuando un cajero aplica
  // descuento global > maxDescuentoCajero% en POS. Texto plano bootstrap.
  pinSupervisor         String    @default("1234")
  // Umbral configurable: por encima de este % el POS exige PIN.
  maxDescuentoCajero    Int       @default(15)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

// ─── Anti-fraude: incidencias de reconciliación diaria ──────────────────────

model IncidenciaReconciliacion {
  id          Int       @id @default(autoincrement())
  tipo        String
  severidad   String    @default("ALTA")
  descripcion String
  datos       Json      @default("{}")
  asignadoA   Int?
  resueltoEn  DateTime?
  resolucion  String?
  empleado    Empleado? @relation(fields: [asignadoA], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())

  @@index([tipo])
  @@index([severidad])
  @@index([resueltoEn])
  @@index([createdAt])
}

// ─── Anti-fraude: foto-evidencia geo-etiquetada de OT ─────────────────────────

model OrdenFoto {
  id          String       @id @default(uuid())
  ordenId     String
  url         String
  latitud     String?
  longitud    String?
  takenAt     DateTime     @default(now())
  subidoPor   Int?
  descripcion String?
  orden       OrdenTrabajo @relation(fields: [ordenId], references: [id], onDelete: Cascade)
  empleado    Empleado?    @relation(fields: [subidoPor], references: [id], onDelete: SetNull)
  createdAt   DateTime     @default(now())

  @@index([ordenId])
  @@index([subidoPor])
  @@index([takenAt])
}

// ─── Seguridad: IP blocking (anti brute-force) ────────────────────────────────

model IpBlock {
  id          Int      @id @default(autoincrement())
  ip          String
  motivo      String   @default("Brute force tracking")
  intentos    Int      @default(0)
  bloqueadoEn DateTime @default(now())
  expiraEn    DateTime

  @@index([ip])
  @@index([expiraEn])
}

// ─── Taller (RMA) ─────────────────────────────────────────────────────────────

model TicketTaller {
  id              String             @id @default(uuid())
  noTicket        String             @unique
  codigoPin       String             @unique
  clienteId       String
  tecnicoId       Int?
  equipo          String
  marca           String?
  modelo          String?
  numeroSerie     String?
  falla           String
  estado          EstadoTicketTaller @default(Recibido)
  notas           String?
  diagnostico     String?
  costoEstimado   Decimal?           @db.Decimal(12, 2)
  recibidoEn      DateTime           @default(now())
  diagnosticadoEn DateTime?
  listoEn         DateTime?
  entregadoEn     DateTime?
  cliente         Cliente            @relation(fields: [clienteId], references: [id], onDelete: Restrict)
  tecnico         Empleado?          @relation(fields: [tecnicoId], references: [id], onDelete: SetNull)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([clienteId])
  @@index([tecnicoId])
  @@index([estado])
  @@index([codigoPin])
}

// ─── CRM Avanzado: Bóveda PAM ─────────────────────────────────────────────────

model CredencialCliente {
  id          String         @id @default(uuid())
  clienteId   String
  tipo        TipoCredencial
  nombre      String
  ip          String?
  usuario     String
  passwordEnc String
  passwordIv  String
  notas       String?
  cliente     Cliente        @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([clienteId])
  @@index([tipo])
}

// ─── CRM Avanzado: CMDB (Activos Instalados) ──────────────────────────────────

model ActivoCliente {
  id               String           @id @default(uuid())
  clienteId        String
  productoId       Int
  ordenTrabajoId   String?
  cantidad         Int              @default(1)
  fechaInstalacion DateTime         @default(now())
  finGarantia      DateTime?
  numeroSerie      String?
  ubicacion        String?
  notas            String?
  cliente          Cliente          @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  producto         Producto         @relation(fields: [productoId], references: [id], onDelete: Restrict)
  orden            OrdenTrabajo?    @relation(fields: [ordenTrabajoId], references: [id], onDelete: SetNull)
  timeline         ActivoTimeline[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([clienteId])
  @@index([productoId])
  @@index([ordenTrabajoId])
  @@index([finGarantia])
}

model ActivoTimeline {
  id             Int           @id @default(autoincrement())
  activoId       String
  evento         String
  tecnicoId      Int?
  ordenTrabajoId String?
  fecha          DateTime      @default(now())
  notas          String?
  activo         ActivoCliente @relation(fields: [activoId], references: [id], onDelete: Cascade)
  tecnico        Empleado?     @relation(fields: [tecnicoId], references: [id], onDelete: SetNull)
  orden          OrdenTrabajo? @relation(fields: [ordenTrabajoId], references: [id], onDelete: SetNull)
  createdAt      DateTime      @default(now())

  @@index([activoId])
  @@index([tecnicoId])
  @@index([fecha])
}

// ─── Préstamos de equipo ──────────────────────────────────────────────────────

model EquipoPrestamo {
  id                  String                @id @default(uuid())
  clienteId           String
  productoId          Int
  cantidad            Int                   @default(1)
  fechaPrestamo       DateTime              @default(now())
  fechaLimite         DateTime
  fechaDevolucion     DateTime?
  movimientoSalidaId  Int?                  @unique
  movimientoEntradaId Int?                  @unique
  notas               String?
  cliente             Cliente               @relation(fields: [clienteId], references: [id], onDelete: Restrict)
  producto            Producto              @relation(fields: [productoId], references: [id], onDelete: Restrict)
  movimientoSalida    MovimientoInventario? @relation("PrestamoSalida", fields: [movimientoSalidaId], references: [id], onDelete: SetNull)
  movimientoEntrada   MovimientoInventario? @relation("PrestamoEntrada", fields: [movimientoEntradaId], references: [id], onDelete: SetNull)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  @@index([clienteId])
  @@index([productoId])
  @@index([fechaLimite])
  @@index([fechaDevolucion])
}

// ─── Audit trail de caja: fraude interno + descuentos autorizados ────────────
model AuditCaja {
  id         Int      @id @default(autoincrement())
  tipo       String // 'venta' | 'anulacion' | 'descuento_pin' | 'descuento_rechazado'
  empleadoId Int?
  facturaId  String?
  monto      Decimal? @db.Decimal(12, 2)
  descPct    Decimal? @db.Decimal(5, 2) // % de descuento aplicado
  detalle    String?
  ip         String?
  ua         String?
  createdAt  DateTime @default(now())

  @@index([tipo])
  @@index([empleadoId])
  @@index([facturaId])
  @@index([createdAt])
}

// ─── Trazabilidad serializada (CCTV, routers, NVR) ───────────────────────────
model ProductoSerial {
  id            Int       @id @default(autoincrement())
  productoId    Int
  serie         String
  estado        String    @default("Disponible") // Disponible|Vendido|RMA|Defectuoso|Reservado
  ubicacion     String?
  facturaId     String? // ref opcional a la factura donde se vendió
  garantiaHasta DateTime?
  producto      Producto  @relation(fields: [productoId], references: [id], onDelete: Cascade)
  notas         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([productoId, serie])
  @@index([estado])
  @@index([facturaId])
}

// ─── Reserva de stock al cotizar (TTL 72h por default) ───────────────────────
model ReservaInventario {
  id         Int      @id @default(autoincrement())
  productoId Int
  facturaId  String? // cotización asociada (opcional)
  cantidad   Int
  expiraEn   DateTime
  liberada   Boolean  @default(false)
  motivo     String?
  producto   Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@index([productoId])
  @@index([facturaId])
  @@index([expiraEn])
  @@index([liberada])
}

// ─── Bundles para cross-sell en POS ──────────────────────────────────────────
model ProductoBundle {
  id        Int      @id @default(autoincrement())
  padreId   Int
  hijoId    Int
  score     Int      @default(1) // mayor = más relevante
  motivo    String?
  padre     Producto @relation("BundlePadre", fields: [padreId], references: [id], onDelete: Cascade)
  hijo      Producto @relation("BundleHijo", fields: [hijoId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([padreId, hijoId])
  @@index([padreId])
}
